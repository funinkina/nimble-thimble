# Copy to .env and fill in. Only the Groq key is required; embeddings run locally.
# Get a key from the Groq console: https://console.groq.com/keys
GROQ_API_KEY=...

# Optional overrides:
# REPLY_MODEL=openai/gpt-oss-120b
# JUDGE_MODEL=openai/gpt-oss-20b
# DB_PATH=./memory.db

# LLM resilience (seconds / extra attempts on a bad-or-invalid response):
# LLM_TIMEOUT=30
# LLM_RETRIES=2

# Hybrid retrieval — off by default (dense-only is at ceiling on short facts;
# see scripts/eval_retrieval.py). Turn both on for larger/noisier memory stores.
# First use of the reranker downloads a small cross-encoder (~80 MB) once.
# USE_BM25=1
# USE_RERANK=1
